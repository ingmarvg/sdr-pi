# Force LF line endings in the repo (avoid CRLF issues on Windows/WSL2).
* text=auto eol=lf

# Ensure shell scripts are always executable after checkout.
*.sh text eol=lf
scripts/sdr-pi-* text eol=lf
pi-gen-stage/*/prerun.sh text eol=lf
pi-gen-stage/*/*-run.sh text eol=lf

# Binary files — do not convert line endings.
*.img binary
*.gz binary
*.xz binary
*.zip binary
*.png binary
*.jpg binary
*.json text eol=lf
*.conf text eol=lf
*.service text eol=lf
*.rules text eol=lf
