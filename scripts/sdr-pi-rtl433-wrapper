#!/usr/bin/env bash
# Wrapper for rtl_433 that reads sdr-pi.conf and serves JSON over TCP.
# Clients connect via: nc <pi-ip> 1234
# rtl_433 outputs JSON to stdout, piped through ncat which serves it
# to all connected TCP clients on the configured port.
# Also decodes Wireless M-Bus, Z-Wave, and Amazon Sidewalk on ISM bands.
set -euo pipefail

source /etc/sdr-pi/sdr-pi.conf

DEVICE_ARG=""
if [[ -n "${RTL433_DEVICE_SERIAL:-}" ]]; then
    DEVICE_ARG="-d :${RTL433_DEVICE_SERIAL}"
fi

GAIN_ARG=""
if [[ "${RTL433_GAIN:-auto}" != "auto" ]]; then
    GAIN_ARG="-g ${RTL433_GAIN}"
fi

FREQ_ARGS="-f ${RTL433_FREQUENCY:-315M}"
if [[ -n "${RTL433_FREQUENCY_2:-}" ]]; then
    FREQ_ARGS="${FREQ_ARGS} -f ${RTL433_FREQUENCY_2}"
fi

PORT="${RTL433_PORT:-1234}"

# NOTE: RTL433_EXTRA_ARGS is intentionally unquoted to allow word-splitting
# into separate arguments. Values must not contain shell metacharacters.
# ncat -lk: listen, keep-alive (accept multiple clients)
# --send-only: don't read from clients, just broadcast rtl_433 output
exec rtl_433 \
    ${FREQ_ARGS} \
    ${DEVICE_ARG} \
    ${GAIN_ARG} \
    -F json \
    ${RTL433_EXTRA_ARGS:-} \
    2>&1 | ncat -lk --send-only 0.0.0.0 "${PORT}"
